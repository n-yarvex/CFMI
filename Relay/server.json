{
  "tag": "xhttp-in",
  "listen": "0.0.0.0",
  "port": 2096,
  "protocol": "vless",
  "settings": {
    "clients": [
      { "id": "YOUR-UUID-HERE", "flow": "" }
    ],
    "decryption": "none"
  },
  "streamSettings": {
    "network": "xhttp",
    "security": "reality",
    "realitySettings": {
      "dest": "www.dest.com:443",
      "serverNames": [
        "www.dest.com"
      ],
      "privateKey": "YOUR_PRIVATE_KEY_BASE64",
      "shortIds": [
        ""
      ]
    },
    "xhttpSettings": {
      "path": "/yourpath",
      "host": "xray.yourdomain.com",
      "mode": "auto"
    }
  }
}
